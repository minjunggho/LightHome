# Spectrum project credentials (from photon.codes dashboard)
PROJECT_ID=
PROJECT_SECRET=

# Where the Lighthome backend is running
BACKEND_URL=http://localhost:8000
VIEW=tns

# SAFETY: dry-run logs what it WOULD post and sends nothing. Flip to false only
# when you intend to feed real iMessages from YOUR OWN account into the backend.
PHOTON_DRY_RUN=true

# Optional: restrict to specific conversation/space ids (comma-separated).
# Leave empty to read all inbound iMessages on the linked account.
ALLOWED_SPACES=
