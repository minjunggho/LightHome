# Copy to .env. The mock backend needs NONE of these — they wire up the real
# pipeline (hour 8) and the observability lane (Person 3).

# Claude synthesis layer
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# State store (Contract D). Unset/empty -> DictStateStore fallback.
REDIS_URL=redis://localhost:6379/0

# Record sink backend: unset -> in-memory (wiped on restart).
# "integration" -> Redis-backed sink, survives server restarts.
STORE_BACKEND=integration

# State/turn TTL in seconds. Unset or 0 -> persist indefinitely.
STATE_TTL_SECONDS=

# Sentry — error monitoring + alert-event capture. Unset -> all Sentry calls
# no-op. When set: ERROR logs become issues, endpoint errors + per-request perf
# transactions are captured, and every fired alert / Claude degradation is sent
# as a structured event (structural data only, never message text).
SENTRY_DSN=
SENTRY_ENVIRONMENT=          # defaults to PIPELINE_MODE (mock|live)
SENTRY_RELEASE=              # optional: tag events with a build/commit
SENTRY_TRACES_SAMPLE_RATE=1.0

# Arize Phoenix tracing — the Claude synthesis call is auto-instrumented and
# exported here. Leave empty to disable tracing (pipeline still runs).
PHOENIX_API_KEY=
PHOENIX_PROJECT=lighthome
PHOENIX_COLLECTOR_ENDPOINT=

# Pipeline mode: "mock" (hour 0) | "live" (real extractors + Claude synthesis)
PIPELINE_MODE=mock
