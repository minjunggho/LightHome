# Copy to .env. The mock backend needs NONE of these — they wire up the real
# pipeline (hour 8) and the observability lane (Person 3).

# Claude synthesis layer
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# State store (Contract D). Unset/empty -> DictStateStore fallback.
REDIS_URL=redis://localhost:6379/0

# Record sink (Contract E)
ARIZE_API_KEY=
ARIZE_SPACE_ID=
SENTRY_DSN=

# Pipeline mode: "mock" (hour 0) | "live" (hour 8)
PIPELINE_MODE=mock
